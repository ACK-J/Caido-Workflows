              "data": "/**\n * @param {HttpInput} input\n * @param {SDK} sdk\n * @returns {MaybePromise<Data | undefined>}\n */\nexport async function run({ request, response }, sdk) {\n  let url = new URL(request.getUrl());\n  await sdk.findings.create({\n      title: \"Salesforce Aura Endpoint Discovered\",\n      description: `Request to \\`/aura\\` endpoint contains a \\`message\\` parameter.\\n\\nCheck the Aura endpoint for data exposure as discussed in this Mandiant blog\\nhttps://cloud.google.com/blog/topics/threat-intelligence/auditing-salesforce-aura-data-exposure\\n\\nUse this Aura Inspector fork to exfiltrate data\\nhttps://github.com/ACK-J/aura-inspector\\n\\nExample Command: \\`python3 ./aura_cli.py -u \"https://example.com\" -k -o ./results --fetch-all\\``,\n      reporter: \"workflow\",\n      request: request,\n      dedupeKey: `aura-message-${url.hostname}-${url.pathname}`\n    });\n}",
              "kind": "string"
            }
          }
        ],
